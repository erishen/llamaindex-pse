OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_MODEL=your-model-name
# AGNES_KEY=your-agnes-key
# AGNES_BASE_URL=https://api.example.com/v1
PSE_MAX_RETRIES=3

# 工作区根目录——read_file / run_bash 沙箱的根路径
PSE_ROOT=/path/to/your/workspace

# Embedding 模型（RAG 索引用）
# EMBEDDING_PROVIDER=openai|ollama（默认 openai）
EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=your-embedding-api-key     # 默认复用 OPENAI_API_KEY
# EMBEDDING_BASE_URL=https://api.example.com/v1  # 默认复用 OPENAI_BASE_URL
EMBEDDING_MODEL=deepseek-embedding

# Ollama（EMBEDDING_PROVIDER=ollama 时使用）
# OLLAMA_BASE_URL=http://localhost:11434

# 简历任务配置
# RESUME_COMPANY_PERIODS={"CompanyA":"Start~End","CompanyB":"Start~End"}
# RESUME_REQUIRED_COMPANIES=CompanyA,CompanyB
RESUME_SOURCE_FILE=ai-engineering.md
# RESUME_LATEST_COMPANY_END=End-Date
# RESUME_DEFAULT_POSITION=
# RESUME_DEFAULT_LOCATION=
# RESUME_DEFAULT_DIRECTION=
# RESUME_RAG_KEYWORDS=
# RESUME_TARGET_ROLE=
# RESUME_BANNED_YEARS=
# RESUME_LATE_START_FIX=
# RESUME_WRONG_TITLE=
# RESUME_CORRECT_TITLE=
# RESUME_HALLUCINATIONS=
# GITHUB_USERNAME=
